{
  "name": "ai-agent-learn",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "《从前端到 AI Agent 开发》配套可运行代码 —— 默认离线 mock 模式，可切换真实模型",
  "scripts": {
    "test": "node scripts/run-all.mjs",
