    "real-smoke": "tsx scripts/real-smoke.ts",
    "real-smoke:py": "uv run python scripts/real-smoke.py"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "openai": "^4.73.0"
  }
}
